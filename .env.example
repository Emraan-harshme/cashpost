# Your gateway URL with /v1 at the end. Set on Render: VITE_GATEWAY_URL
# See DEPLOY.md for setup steps.
VITE_GATEWAY_URL=

# Optional: must match STOREFRONT_TOKEN in your gateway.
VITE_STOREFRONT_TOKEN=

VITE_OPERATOR_NAME=CashPost

# Optional: "Sign in with Google" (see GOOGLE_AUTH.md). Leave blank to disable.
VITE_GOOGLE_CLIENT_ID=
