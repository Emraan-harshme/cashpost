# ── The operator storefront gateway ─────────────────────────
# This backend holds your SECRET Redwire operator API key. It must NEVER
# be exposed to the browser. Only the frontend's public VITE_GATEWAY_URL is.

PORT=8080

# Your Redwire operator API key (the secret one). Stays server-side, here only.
REDWIRE_API_KEY=
REDWIRE_API_BASE_URL=https://api.redwire.work/v1

# Comma-separated list of frontend origins allowed to call this gateway.
# e.g. https://my-store.onrender.com,https://mystore.com
ALLOWED_ORIGINS=

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Optional shared, non-secret token baked into the frontend build and checked
# here. Cuts anonymous abuse of your gateway URL. Leave blank to disable.
STOREFRONT_TOKEN=

# ── Optional: run the Discord bot in this same process ──────
RUN_BOT=false

# Only needed if RUN_BOT=true (see the bot README for details):
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
OPERATOR_NAME=
TASK_COOLDOWN_HOURS=6
REJECT_LIMIT_PER_DAY=3
DELIVERY_MODE=ticket
OPERATOR_LOG_CHANNEL_ID=
STAFF_ROLE_ID=
TICKET_CATEGORY_ID=

# Optional Leah remote control (needs RUN_BOT=true). By default the owner
# controls this bot with the operator's REDWIRE_API_KEY (already above). Only set
# LEAH_KEY if you want a SEPARATE control secret. Endpoints: POST /admin/invite,
# POST /admin/broadcast.
LEAH_KEY=
